# Reference template for required backend variables.
# For local development copy these keys to .env.local instead.

DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DB_SSLMODE=require

SUPABASE_URL=https://<project-ref>.supabase.co
# Optional if you prefer to set the JWKS endpoint explicitly.
# SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# Legacy fallback only. Prefer JWKS via SUPABASE_URL.
# SUPABASE_JWT_SECRET=<legacy_jwt_secret>

# Add the dashboard origin for the environment where this API runs.
CORS_ORIGINS=https://your-dashboard.example.com
# Optional if you also want Vercel preview deployments to call the API.
# CORS_ORIGIN_REGEX=^https://.*\\.vercel\\.app$
CORS_ALLOW_CREDENTIALS=true

# Optional tuning for gunicorn on Linux hosts.
WEB_CONCURRENCY=1
GUNICORN_TIMEOUT=600
